    function getBatchSummaryReport() {

        var doctor_id = $("#doctor_id").val() || 0;
        var batch_id = $("#batch_id").val() || 0;
        var payment_status = $("#payment_status").val() || "Select";

        $("#btnSearch").text("Searching...");

        $.ajax({
            url: "/Report/GetBatchSummaryReport",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({
                doctor_id: doctor_id,
                batch_id: batch_id,
                payment_status: payment_status
            }),
            success: function (response) {

                $("#btnSearch").text("Search");

                if ($.fn.DataTable.isDataTable('#table_id')) {
                    $('#table_id').DataTable().clear().destroy();
                }

                var tbody = $("#table_id tbody");
                tbody.empty();

                $.each(response, function (index, item) {

                    tbody.append(`
                        <tr class="text-center">
                            <td>${index + 1}</td>
                            <td>${item.employeename || ''}</td>
                            <td>${item.patient_name || ''}</td>
                            <td>${item.treatment_type || ''}</td>
                            <td>${item.band || ''}</td>
                            <td>${item.batch_no || ''}</td>
                            <td>${formatDate(item.batch_date)}</td>
                            <td>${item.lot_no || ''}</td>
                            <td>${formatDate(item.lot_date)}</td>
                            <td>${formatDate(item.sanction_date)}</td>
                            <td>${formatDate(item.sent_to_tmo)}</td>
                            <td>${formatDate(item.received_from_tmo)}</td>
                            <td>${item.doctor_name || ''}</td>
                            <td>${item.batch_id || ''}</td>
                        </tr>
                    `);
                });

                $('#table_id').DataTable({
                    lengthMenu: [[10, 25, 50, -1], [10, 25, 50, "All"]],
                    destroy: true
                });
            }
        });
    }


    function formatDate(dateString) {

        if (!dateString)
            return "";

        var date = new Date(dateString);

        if (isNaN(date))
            return "";

        var day = ("0" + date.getDate()).slice(-2);
        var month = ("0" + (date.getMonth() + 1)).slice(-2);
        var year = date.getFullYear();

        return day + "-" + month + "-" + year;
    }

</script>
