@{
    ViewBag.Title = "MedicalRBatchSummaryReport";
}

<div class="container-fluid headtop">
    <div class="row">
        <div class="col-md-12 p-0">
            <ul class="nav">
                <li class="nav-item">
                    <a class="nav-link text-dark"><strong>Statistics ></strong></a>
                </li>
                <li class="nav-item">
                    <a class="nav-link">Batchwise Summary Report</a>
                </li>
            </ul>
            <hr class="m-0">
        </div>

        <article class="col-md-12">
            <br />
            <div class="form-row">

                <div class="form-group col-md-3">
                    <label>Doctor Name</label>
                    @Html.DropDownList(
                       "doctor_id",
                       new SelectList(ViewBag.Doctors, "id", "name"),
                       "Select",
                       new { @class = "form-control", id = "doctor_id" })
                </div>

                <div class="form-group col-md-3">
                    <label>Batch No.</label>
                    @Html.DropDownList(
                      "batch_id",
                      new SelectList(ViewBag.Batches, "id", "name"),
                      "Select",
                      new { @class = "form-control", id = "batch_id" })
                </div>

                <div class="form-group col-md-3">
                    <label>Payment Status</label>
                    <select id="payment_status" class="form-control">
                        <option value="">Select</option>
                        <option value="PAID">PAID</option>
                        <option value="UNPAID">UNPAID</option>
                    </select>
                </div>

            </div>

            <div class="row">
                <div class="form-group col-sm-1">
                    <label>.</label>
                    <button type="button" id="btnSearch" class="btn btn-primary form-control">Search</button>
                </div>

                <div class="form-group col-sm-1">
                    <label>.</label>
                    <a id="btnDownload" class="btn btn-primary form-control" href="#">Download</a>
                </div>
            </div>

        </article>
    </div>

    <div class="row mt-3">
        <div class="col-md-12">
            <div class="overflow-auto">
                <table class="table table-hover table-bordered" id="table_id">
                    <thead>
                        <tr class="bg-primary text-white text-center">
                            <th>SrNo.</th>
                            <th>Employee Name</th>
                            <th>Patient Name</th>
                            <th>Treatment Type</th>
                            <th>Band</th>
                            <th>Batch No</th>
                            <th>Batch Date</th>
                            <th>Lot No</th>
                            <th>Lot Date</th>
                            <th>Sanction Date</th>
                            <th>Sent To Tmo</th>
                            <th>Received From Tmo</th>
                            <th>Doctor Name</th>
                            <th>Batch Id</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

