            </div>
            <div class="form-group col-md-4">
                <label for="">Appointment No: <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="appointmentno_spouse">
            </div>
        </div>

        @*<div class="form-row">
                <div class="form-group col-md-6">
                    <label for="">Remark for Rejection (if any)</label>
                    <input type="text" class="form-control" id="rejection_remark">
                </div>
            </div>*@
    }
    <div class="form-row">
        <div class="form-group col-md-6">
            <label for="">Remark for Rejection (if any)</label>
            <input type="text" class="form-control" id="rejection_remark">
        </div>
    </div>
    <div class="row">
        <input type="text" hidden class="form-control" id="relationship" value="@Model.relationship">
        <input type="text" hidden class="form-control" id="emplid" value="@Model.emplid">


        <div class="form-group col-md-4"></div>
        <div class="form-group col-md-2"> <a href="javascript:void(0)" class="btn btn-primary" id="Reject" data-val="1">Reject<span class="spinner"></span></a> </div>
        @if (Model.status == "Approved")
        {
            @*<div class="form-group col-md-2"> <a href="javascript:void(0)" class="btn btn-primary" id="Approve" data-val="1" style="pointer-events: none">Approve<span class="spinner"></span></a> </div>*@
        }
        else
        {
            <div class="form-group col-md-2"> <a href="javascript:void(0)" class="btn btn-primary" id="Approve" data-val="1">Approve<span class="spinner"></span></a> </div>
        }
    </div>

</form>


