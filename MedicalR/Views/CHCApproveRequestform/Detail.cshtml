                    <li class="nav-item @(@ViewBag.Client_ID > 0 ? "" :"disabled")" role="presentation" data-tab="notes"> <a href="javascript:void(0);" class="nav-link" data-target="/CHCApproveRequestform/_Notes?PageID=1">Notes</a> </li>
                    <li class="nav-item @(@ViewBag.Client_ID > 0 ? "" :"disabled")" role="presentation" data-tab="attachments"> <a href="javascript:void(0);" class="nav-link" data-target="/CHCApproveRequestform/Attachments?PageID=1">Attachments</a> </li>*@

            </ul>
            <hr>

            <div class="tab-content" id="client-tabContent">

            </div>
