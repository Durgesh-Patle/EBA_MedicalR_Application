</article>
<input type="hidden" value="0" id="employee_id" class="hdnRelevantID" />
<input type="hidden" value="@ViewBag.Client_ID" id="emplid" class="hdnRelevantID" />
<input type="hidden" value="@ViewBag.EmpCode" id="EmpCode" class="hdnRelevantID" />

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

<script>
    var clientID = @ViewBag.Client_ID;
    var activeTab = window.location.hash.substring(1);
    if(activeTab=="" || clientID>0)
    {
        activeTab="info";
        window.location.hash = '#'+activeTab;

    }
    var activeView = $("#clients-tab li[data-tab='"+activeTab+"']").find("a.nav-link").data("target");
    LoadClientViews(activeView);
    LoadEmpsidebarViews();

    function LoadClientViews(targetView)
    {
        $("#clients-tab a").removeClass("active");
        $("#clients-tab a[data-target='" + targetView + "']").addClass("active");
        $("#loader").show();
        $.ajax({
            url: targetView,
            type: "post",
            data :{"clientID":clientID},
            dataType: "html",
            success: function (result) {
                $("#client-tabContent").html(result);
                $('#client-tabContent table').DataTable();
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    window.location.reload();
                    return;
                }
                $("#loader").hide();
            }

        });
    }
    function LoadEmpsidebarViews()
    {
        $.ajax({
            url: "/CHCApproveRequestform/_Empsidebarinfo",
            type: "post",
            dataType: "html",
            success: function (result) {
                $("#client-sidebar-info").html(result);
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    window.location.reload();
                    return;
                }
            }

        });
    }
    $(document).ready(function () {
        $("#clients-tab a.nav-link").click(function () {
            var tab = $(this).parent().data("tab");
            window.location.hash = '#' + tab;

            var targetView = $(this).data("target");
            LoadClientViews(targetView);

        })

