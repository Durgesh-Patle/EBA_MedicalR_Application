
@{
    ViewBag.Title = "Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="col-md-12 p-0">
    <ul class="nav">
        <li class="nav-item"> <a class="nav-link" href="/CHCRequestform">Statistics</a> </li>
        @*<li class="nav-item"> <a class="nav-link text-dark" href="javascript:void(0);"><strong>Request form</strong></a> </li>*@

    </ul>
    <hr class="m-0">
</div>
<article class="col-md-12">
    <div class="row pt-2 bg-light"> </div>
    <div class="row">
        <div class="col-md-3 shadow p-0">
            <hr class="mb-0 mt-0 border-top-0">
            <div class="list-group list-group-flush" id="client-sidebar-info">


            </div>
        </div>
        <div class="col-md-9 mt-3">
            <ul class="nav nav-pills mb-3" id="clients-tab" role="tablist">
                <li class="nav-item" role="presentation" data-tab="info"> <a href="javascript:void(0);" class="nav-link active" data-target="/CHCApproveRequestform/_ApproveRequest/@ViewBag.Client_ID">New Request</a> </li>

                @*<li class="nav-item" role="presentation" data-tab="info"> <a href="javascript:void(0);" class="nav-link active" data-target="/MedicalRequest/_NewRequest">New Request</a> </li>*@
