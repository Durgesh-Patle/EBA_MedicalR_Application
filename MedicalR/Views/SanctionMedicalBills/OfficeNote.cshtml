                    <li class="nav-item"> <a class="nav-link" href="#">Bill Process</a> </li>
                </ul>*@
            <hr class="m-0">
        </div>
        <article class="col-md-12">
            <div class="pt-3">
            </div>
            <div class="pt-3">
            </div>
            <div class="pt-3">
            </div>
            <div class="pt-3">

            </div>
            <div class="row">
                <div class="form-group col-md-6"></div>
                <div class="form-group col-md-4"></div>
                <button type="button" class="btn-primary" onclick="getPDF()">Print</button>
            </div>
            <div class="PDF">
                <div class="row" id="contnet">
                    <div class="header">
                        <h3 style="text-align: center"><strong>Assest Management Company Ltd.</strong></h3>
                        <p style="text-align: center"><strong>UTI Tower , Gn Block</strong></p>
                        <p style="text-align: center"><strong>Bandra Kurla Complex</strong></p>
                        <p style="text-align: center"><strong>Bandra(East), Mumbai - 400051</strong></p>
                        <p style="text-align: center"><span>Phone </span><span style="word-spacing:1px ">:66786542</span><span style="word-spacing: 100px">. Fax</span><span style="word-spacing:1px "> : 26528991</span> </p>
                        @*<%--  <p style="text-align:center"><span style=""> </span><br /><span style="word-spacing:60px"> </span></p>--%>*@
                    </div>
                    <div class="contents">
                        <p>Ref : UT/DOAA/___________________/2020-2021</p>
                        <h2 style="text-align:center; color:cornflowerblue">Office Note</h2>

                        <p>We are reimbursing the Medical Bills for the employees who have already applied for availing their claim.</p>
                        <p>We enclose the list of batches which are already processed for payment,the details are as below.</p>

                        <table id="dtBasicExample" class="table table-hover table-bordered" cellspacing="0" width="100%">
                            <thead>
                                <tr>


                                    <th class="th-sm">Batch ID</th>
                                    <th class="th-sm">Status</th>
                                    <th class="th-sm">Record Counts</th>
                                    <th class="th-sm">Claimed Rs.</th>
                                    <th class="th-sm">Sanctioned Rs.</th>


                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
