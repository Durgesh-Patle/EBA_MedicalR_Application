            <div class="row">
                <div class="form-group col-md-3"></div>
                <div class="form-group col-md-3">
                    <button type="button" class="btn-primary" onclick="ViewAnnexure()">View-Annexure</button>
                </div>
                <div class="form-group col-md-3">
                    <button type="button" class="btn-primary">Done and Proceed for Next..</button>
                </div>

            </div>
            <div id="elementH"></div>
            @* </div> *@

        </article>
