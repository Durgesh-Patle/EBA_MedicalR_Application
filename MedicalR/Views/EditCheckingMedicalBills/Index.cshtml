@model IEnumerable<MedicalR.Models.MedicalR.EditCheckingBillsModel>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid headtop">
    <div class="row">

        <div class="col-md-12 p-0">
            <ul class="nav">
                <li class="nav-item">
                    <a class="nav-link text-dark" href="javascript:void(0);">
                        <strong>Statistics</strong>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        Edit Checking Medical Bills
                    </a>
                </li>
            </ul>
            <hr class="m-0">
        </div>

        <article class="col-md-12">
            <br />

            <div class="form-row">
                <div class="form-group col-sm-1">
                    <a href="/EditCheckingMedicalBills/download/0"
                       class="form-control btn btn-primary">
                        Print
                    </a>
                </div>
            </div>

            <table id="table_id"
                   class="table table-hover table-bordered"
                   cellspacing="0"
                   width="100%">
                <thead>
                    <tr>
                        <th>Employee Code</th>
                        <th>Name</th>
                        <th>Appln.No</th>
                        <th>Date of Request</th>
                        <th>Batch No</th>
                        <th>Batch Date</th>
                        <th>Total Claimed Rs.</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>

        </article>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

<script>

    $(document).ready(function () {

        loadGridData();

    });


    // LOAD GRID DATA
    function loadGridData() {

        $.ajax({
            url: "/EditCheckingMedicalBills/GetEditCheckingMedicalBillsGrid_Data",
            type: "POST",
            dataType: "json",
            success: function (response) {

                initializeDataTable(response);

            },
            error: function (xhr) {

                if (xhr.status === 401) {
                    window.location.reload();
                    return;
                }

                toastr["error"]("Something went wrong. Please try again.");
            }
        });
    }


    // INITIALIZE DATATABLE
    function initializeDataTable(data) {

        $("#table_id").DataTable({
            bLengthChange: true,
            lengthMenu: [[10, 15, 20, -1], [10, 15, 20, "All"]],
            bFilter: true,
            bSort: true,
            bPaginate: true,
            destroy: true,
            data: data,

            columns: [

                { data: 'employeecode' },

                { data: 'employeename' },

                {
                    data: 'appln_no',
                    render: function (data, type, row) {
                        return '<a href="/EditCheckingMedicalBills/Detail/' +
                            row.claim_request_id + '">' +
                            row.appln_no + '</a>';
                    }
                },

                {
                    data: 'date_of_request',
                    render: function (data) {
                        return formatDate(data);
                    }
                },

                {
                    data: 'batch_no',
                    render: function (data, type, row) {
                        return '<a href="/BatchCreation/BatchItems/' +
                            row.batch_no + '">' +
                            row.batch_no + '</a>';
                    }
                },

                {
                    data: 'batch_date',
                    render: function (data) {
                        return formatDate(data);
                    }
                },

                { data: 'total_claimed_rs' }

            ]
        });
    }


    // DATE FORMAT FUNCTION
    function formatDate(data) {

        if (!data) return "";

        var date;

        // Handle .NET JSON Date format: /Date(1708387200000)/
        if (typeof data === "string" && data.indexOf("/Date(") === 0) {
            var timestamp = parseInt(data.replace(/[^0-9]/g, ""));
            date = new Date(timestamp);
        }
        else {
            date = new Date(data);
        }

        if (isNaN(date.getTime())) return "";

        var day = ("0" + date.getDate()).slice(-2);
        var month = ("0" + (date.getMonth() + 1)).slice(-2);
        var year = date.getFullYear();

        return day + "/" + month + "/" + year;
    }


    // VERIFY BATCH
    function verify(batch_id) {

        $.ajax({
            url: "/EditCheckingMedicalBills/verified",
            type: "POST",
            data: { batch_id: batch_id },
            dataType: "json",

            success: function (result) {

                if (result.Status === true) {
                    toastr["success"](result.Message);
                    window.location.href = "/EditCheckingMedicalBills";
                }
                else {
                    toastr["error"](result.Message);
                }
            },

            error: function (xhr) {

                if (xhr.status === 401) {
                    window.location.reload();
                    return;
                }

                toastr["error"]("Something went wrong. Please try after some time.");
            }
        });
    }


    // VERIFIED FUNCTION
    function verified(EditChecking) {

        if (EditChecking === "EditChecking") {
            window.location.href = "/MedicalAcknowlledge";
        }
        else {
            verify(EditChecking);
        }
    }


    // SIDE NAVIGATION
    function openNav() {
        $("#mySidenav").css("width", "250px");
    }

    function closeNav() {
        $("#mySidenav").css("width", "0");
    }

</script>


