    function bindEvents() {

        // ---- Sanction Amount input change (ng-change="calculateSactionAmt(...)") ----
        $(document).off('input.sanc').on('input.sanc', '.sanc-amt-input', function () {
            var parentIndex = parseInt($(this).data('parent-index'));
            var childIndex = parseInt($(this).data('child-index'));
            var val = $(this).val();

            // Sync back to model object
            model.expense_type_detalis[parentIndex]
                .request_claim_expense_items[childIndex].amt_sanctioned_rs = val;

            // Update disabled state of objection code & MA remark
            // (mirrors ng-disabled="item2.amt_claimed_rs==item2.amt_sanctioned_rs")
            var claimedAmt = parseFloat($(this).data('claimed'));
            var sanctAmt = parseFloat(val);
            var isSame = (claimedAmt === sanctAmt);

            var $row = $(this).closest('tr');
            $row.find('.objection-code-select').prop('disabled', isSame);
            $row.find('.ma-remark-input').prop('disabled', isSame);

            // Run same calculation as Angular
            calculateSactionAmt();
        });

        // ---- Objection Code select change (ng-model sync) ----
        $(document).off('change.obj').on('change.obj', '.objection-code-select', function () {
            var parentIndex = parseInt($(this).data('parent-index'));
            var childIndex = parseInt($(this).data('child-index'));
            model.expense_type_detalis[parentIndex]
                .request_claim_expense_items[childIndex].objection_code_id = parseInt($(this).val());
        });

        // ---- MA Remark input change (ng-model sync) ----
        $(document).off('input.maremark').on('input.maremark', '.ma-remark-input', function () {
            var parentIndex = parseInt($(this).data('parent-index'));
            var childIndex = parseInt($(this).data('child-index'));
            model.expense_type_detalis[parentIndex]
                .request_claim_expense_items[childIndex].ma_remark = $(this).val();
        });

        // ---- Hospital section: expense from/to date (ng-model sync) ----
        $(document).off('change.expdate').on('change.expdate', '.expense-from-date, .expense-to-date', function () {
            var parentIndex = parseInt($(this).data('parent-index'));
            var field = $(this).hasClass('expense-from-date') ? 'from_date' : 'to_date';
            model.expense_type_detalis[parentIndex][field] = $(this).val();
        });

        // ---- Hospital name input (ng-model sync) ----
        $(document).off('input.hospital').on('input.hospital', '.expense-hospital-name', function () {
            var parentIndex = parseInt($(this).data('parent-index'));
            model.expense_type_detalis[parentIndex].hospital_name = $(this).val();
        });
    }

    function save() {
        // ---- Validate: objection code must be selected if claimed != sanctioned ----
        // (same loop as Angular $scope.save)
        for (var k = 0; k < model.expense_type_detalis.length; k++) {
            for (var k2 = 0; k2 < model.expense_type_detalis[k].request_claim_expense_items.length; k2++) {

                var item = model.expense_type_detalis[k].request_claim_expense_items[k2];

                // Same console.log as original
                console.log('Item [' + k + '][' + k2 + '] - Claimed: ' + item.amt_claimed_rs +
                    ', Sanctioned: ' + item.amt_sanctioned_rs +
                    ', Objection Code: ' + item.objection_code_id);

                if (item.amt_claimed_rs !== parseFloat(item.amt_sanctioned_rs)) {
                    if (!item.objection_code_id || item.objection_code_id === 0) {
                        toastr['error']('Please select objection code !');
                        return;
                    }
                }
            }
        }

        // ---- Post to server (replaces EditCheckingDetailsFactory.save) ----
        $.post('/EditCheckingMedicalBills/Save', { model: model })
            .done(function (success) {
                if (success.Status) {
                    toastr['success'](success.Message);
                    window.location.href = window.location.origin + '/EditCheckingMedicalBills';
                } else {
                    toastr['error'](success.Message);
                }
            })
            .fail(function () {
                toastr['error']('Request failed. Please try again.');
            });
    }

    function init() {
        var id = getIdFromUrl();

        $.when(
            $.post('/EditCheckingMedicalBills/GetItem', { id: id }),
            $.get('/Common/GetObjectionCodes/')
        ).done(function (res1, res2) {

            var itemResponse = res1[0];
            var objCodesResponse = res2[0];

            model = itemResponse.data !== undefined ? itemResponse.data : itemResponse;
            objection_codes = objCodesResponse.data !== undefined ? objCodesResponse.data : objCodesResponse;

            //  Safety check — agar array nahi mila to empty array use karo
            if (!Array.isArray(objection_codes)) {
                objection_codes = [];
            }

            if (!model) {
                toastr['error']('Model data load ');
                return;
            }

            // Same loop as before
            if (model.id > 0) {
                for (var k = 0; k < model.expense_type_detalis.length; k++) {
                    showhidefields(model.expense_type_detalis[k].expense_type_code, k);
                }
            }

            populateTopForm();
            buildExpenseTypesUI();

        }).fail(function (err) {
            console.error('API call failed:', err);
            toastr['error']('Failed to load data. Please refresh the page.');
        });
    }

    $(document).ready(function () {

        // Init data load
        init();

        // Save button click (replaces ng-click="save()")
        $('#btnSave').on('click', function () {
            save();
        });
    });

</script>