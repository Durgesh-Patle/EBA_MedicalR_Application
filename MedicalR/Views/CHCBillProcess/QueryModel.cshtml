@model IEnumerable<MedicalR.Models.CHC.CHCBillProcess>
@{
    ViewBag.Title = "Query Module";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="col-md-12 p-0">
    <ul class="nav">

        <li class="nav-item"> <a class="nav-link text-dark" href="javascript:void(0);"><strong>Query Model </strong></a> </li>
    </ul>
    <hr class="m-0">
</div>
<article class="col-md-12">
    <div class="col-md-12 p-0">
        <ul class="nav">
            <li class="nav-item"> <a class="nav-link" href="#">Statistics ></a> </li>
            <li class="nav-item"> <a class="nav-link text-dark" href="javascript:void(0);"><strong>Query Module </strong></a> </li>

        </ul>
        <hr class="m-0">
    </div>
    <br>
    <br />
    <form>
        <div class="col-md-12">
            <div class="form-row">

                <div class="form-group col-md-1">
                    <label for="">Lot No:</label>
                </div>
                <div class="form-group col-md-2">
                    <select class="form-control select2" id="lot_no">
                        <option value="">Select Lot No</option>
                        @foreach (var item in Model)
                        {

                            <option value="@item.lot_no">@item.lot_no</option>
                        }
                    </select>

                </div>
                &nbsp;&nbsp;
                <div class="form-group col-md-1">
                    <label for="">Empl Code:</label>
                </div>
                <div class="form-group col-md-2">
                    <input type="text" class="form-control" id="Empcode">
                </div>

                &nbsp;&nbsp;

                @*<div class="form-group col-md-1"></div>*@
                <div class="form-group col-md-1">
                    <button type="button" class="btn btn-primary" onclick="ViewAnnexure()">Search</button>
                </div>

                @*<div class="form-group col-md-2">
                        <button type="button" class="btn btn-info" onclick="Viewpending()">View Pending List</button>
                    </div>*@
                @*<div class="form-group col-md-1"></div>*@


            </div>

        </div>
        <div class="col-md-12">
            <div class="form-row">

                <div class="form-group col-md-2">
                    <button type="button" class="btn btn-primary" id="exportSubmit" onclick="ViewofficeNote()">Download Office Note</button>
                    @*<span style="cursor:pointer" onclick="openBar()"></span> <a href="/ReitredEmployee/OfficeNote/">View Office Note</a>*@

                </div>
                <div class="form-group col-md-2">
                    <button type="button" class="btn btn-primary" id="bankadvise" onclick="BankAdvise()">Download Bank Advise</button>
                    @*<span style="cursor:pointer" onclick="openBar()"></span> <a href="/ReitredEmployee/OfficeNote/">View Office Note</a>*@

                </div>

                @*<div class="form-group col-md-1">
                        <button type="button" class="btn btn-primary" onclick="getPDF()">Print</button>
                    </div>*@
            </div>
        </div>
        <div class="PDF">

            <table id="dtBasicExample" class="table table-hover table-bordered" cellspacing="0" width="100%">
                <thead>
                    <tr>
                        <th class="th-sm">Empl Code</th>
                        <th class="th-sm">Name</th>
                        <th class="th-sm">CHC Centres</th>
                        <th class="th-sm">Date Of Checkup</th>
                        <th class="th-sm">Lot No</th>
                        <th class="th-sm">Lot Date</th>
                        <th class="th-sm">Bill No</th>
                        <th class="th-sm">Amount</th>
                        <th class="th-sm">Status</th>


                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </form>

    <form id="exportData" action="/CHCBillProcess/Officenotepdf" style="display:none">
        <input type="text" value="lot" name="lot" />
        <input type="text" value="lot_no" name="lotno" />
        @*<input type="text" value="" name="ToDate" />*@
    </form>
    <form id="exportData1" action="/CHCBillProcess/Bankadvicepdf" style="display:none">
        <input type="text" value="lot" name="lot" />
        <input type="text" value="lot_no" name="lotno" />
        @*<input type="text" value="" name="ToDate" />*@
    </form>
</article>

<script src="https://code.jquery.com/jquery-3.7.1.min.js" />

