        crossorigin="anonymous"
        referrerpolicy="no-referrer"></script>*@


<script src="~/Includes/js/jspdf.min.js"></script>

    <script src="~/Includes/js/html2canvas.js"></script>
<script>

    function BankAdvise() {
        var lotno = $("#lot_no").val().trim();
        if (lotno == '') {
            alert("Please select Lot No");
        }
        else {

            var lots = $("#lot").val();
            //var ToDate = $("#TO_DATE").val();
            var lotno = $("#lot_no").val();
            $("#exportData1 input[name=lot]").val("test");
            $("#exportData1 input[name=lotno]").val(lotno);
            //$("#exportData input[name=ToDate]").val(ToDate);
            $("#exportData1").submit();

            //  window.location.href = "/CHCBillProcess/BankAdvise/" + lotno;

        }

    }
    function ViewofficeNote() {
        var lotno = $("#lot_no").val().trim();
        if (lotno == '') {
            alert("Please select Lot No");
        }
        else {

            var lots = $("#lot").val();
            //var ToDate = $("#TO_DATE").val();
            var lotno = $("#lot_no").val();
            $("#exportData input[name=lot]").val("test");
            $("#exportData input[name=lotno]").val(lotno);
            //$("#exportData input[name=ToDate]").val(ToDate);
            $("#exportData").submit();

        }



    }
    function ViewAnnexure() {

        var lot_no = $("#lot_no").val().trim();
        var employee_code = $("#Empcode").val().trim();
        //if (lot_no == '') {
        //    alert("Please select Lot No");
        //}

        //else {
        // var lot_no = $("#lot_no option:selected").Text().trim();
        // if (lot_no == 0) {
        var data = {

            "lot_no": lot_no,
            "employee_code": employee_code,
        };
        $.ajax({
            url: "/CHCBillProcess/GetdatabyLotNo",
            type: "post",
            data: data,
            dataType: "json",
            success: function (result) {
                $("#dtBasicExample tbody").empty();
                // $("#yearto").empty();
                if (result.length > 0) {
                    for (var i = 0; i < result.length > 0; i++) {
                        var row = '<tr><td> ' + result[i].employeecode + ' </td> <td> ' + result[i].employee_name + ' </td> <td> ' + result[i].hosname + ' </td><td> ' + result[i].date_of_checkup + ' </td> <td>' + result[i].lot_no + '</td> <td>' + result[i].lotdate + '</td> <td>' + result[i].bill_no + '</td> <td>' + result[i].amount + '</td><td>' + result[i].status + '</td> </tr>'
                        $("#dtBasicExample tbody").append(row);
                    }

                }
                else {
                    //var row = '<tr><td> ' + "No Records found" + ' </td></tr>'
                    ////var row = '<tr>' + "No Records found" + '</tr>'
                    //$("#dtBasicExample tbody").append(row);
                    alert("No Records Found ");
                }


            },

        });



        //}
    }
</script>