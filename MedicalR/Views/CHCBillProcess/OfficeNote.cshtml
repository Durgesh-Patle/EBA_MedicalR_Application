<div class="container-fluid">
    <div class="row">
        <div class="col-md-12 p-0">
            @*<ul class="nav">
                    <li class="nav-item"> <a class="nav-link text-dark" href="javascript:void(0);"><strong>Statistics</strong></a> </li>
                    <li class="nav-item"> <a class="nav-link" href="#">Bill Process</a> </li>
                </ul>*@
            <hr class="m-0">
        </div>
        <article class="col-md-12">
            <div class="pt-3">
            </div>
            <div class="pt-3">
            </div>
            <div class="pt-3">
            </div>
            <div class="pt-3">

            </div>
            <div class="row">
                <div class="form-group col-md-6"></div>
                <div class="form-group col-md-4"></div>
                <button type="button" class="btn-primary" onclick="getPDF()">Print</button>
            </div>
            <div class="PDF">
                <div class="row" id="contnet">
                    <div class="header">
                        <h3 style="text-align: center"><strong>Assest Management Company Ltd.</strong></h3>
                        <p style="text-align: center"><strong>UTI Tower , Gn Block</strong></p>
                        <p style="text-align: center"><strong>Bandra Kurla Complex</strong></p>
                        <p style="text-align: center"><strong>Bandra(East), Mumbai - 400051</strong></p>
                        <p style="text-align: center"><span>Phone </span><span style="word-spacing:1px ">:66786542</span><span style="word-spacing: 100px">. Fax</span><span style="word-spacing:1px "> : 26528991</span> </p>
                        @*<%--  <p style="text-align:center"><span style=""> </span><br /><span style="word-spacing:60px"> </span></p>--%>*@
                    </div>
                    <div class="contents">
                        <p>Ref : UT/DOAA/___________________/2020-2021</p>
                        <h2 style="text-align:center; color:cornflowerblue">Office Note</h2>
                        <h6><strong>Ref : Sanction of Comprehensive health check-up Bills at Various C.H.C Centre</strong></h6>
                        <p>We are reimbursing the Bills of Hospitals for the Comprehensive Health Check-Up to the Officers. Officers in the age group of 40 years to 50 years can undergo for comprehensive health check-Up with spouse once in two years and officers above 50 years of age can avail this facility once in a year with spouse.</p>
                        <p>We enclose herewith the comprehensive health check-up Bills of various CHC centres.as details below.</p>

                        <table id="dtBasicExample" class="table table-hover table-bordered" cellspacing="0" width="100%">
                            <thead>
                                <tr>


                                    <th class="th-sm">EmplID</th>
                                    <th class="th-sm">Name of Employee</th>
                                    <th class="th-sm">Name of CHC Center</th>
                                    <th class="th-sm">Bill No</th>
                                    <th class="th-sm">Amount</th>
                                    <th class="th-sm">Tax in Rs.</th>

                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>



                                        <td>@item.emplid</td>
                                        <td>@item.employee_name</td>
                                        <td>@item.hosname</td>
                                        <td hidden id="chc_centerid">@item.chc_centerid</td>
                                        <td>@item.bill_no</td>
                                        <td>@item.amount</td>
                                        <td>@item.tax_in_rs</td>


                                    </tr>
                                }


                            </tbody>
                        </table>
                        @if (Model.Count() == 0)
                        {
                            <div class="no-data-found">No Data Found</div>
                        }
                        <div class="row">
                            <div class="form-group col-md-6"></div>
                            <div class="form-group col-md-2"></div>
                            <div class="form-group col-md-4">
                                <label for="">Sum Amount <span id="val">.</span></label>
                            </div>

                        </div>
                        <p>The above said Bills are in order. if approved, we may pay <span id="value">.</span> to the CHC Centres as mentioned above.</p>
                        <p>Submitted for Approval Please.</p>
                        <p>SAVP (SK)</p>
                    </div>
                </div>
            </div>
            <div id="elementH"></div>
            @* </div> *@

        </article>
    </div>
</div>

<script src="https://www.freakyjolly.com/multipage-canvas-pdf-using-jspdf/"></script>
<script src="https://code.jquery.com/jquery-1.12.4.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/1.3.3/jspdf.min.js"></script>
<script src="https://html2canvas.hertzen.com/dist/html2canvas.js"></script>
<script>
    $(document).ready(function () {
        var table = document.getElementById("dtBasicExample"), sumVal = 0;
        for (i = 1; i < table.rows.length; i++) {
            sumVal = sumVal + parseInt(table.rows[i].cells[5].innerHTML);
        }
        document.getElementById("val").innerHTML = "Rs. =" + sumVal;
        document.getElementById("value").innerHTML = "Rs. =" + sumVal;
    });

    function getPDF() {

        var HTML_Width = $(".PDF").width();
        var HTML_Height = $(".PDF").height();
        var top_left_margin = 15;
        var PDF_Width = HTML_Width + (top_left_margin * 2);
        var PDF_Height = (PDF_Width * 1.5) + (top_left_margin * 2);
        var canvas_image_width = HTML_Width;
        var canvas_image_height = HTML_Height;

        var totalPDFPages = Math.ceil(HTML_Height / PDF_Height) - 1;


        html2canvas($(".PDF")[0], { allowTaint: true }).then(function (canvas) {
            canvas.getContext('2d');

            console.log(canvas.height + "  " + canvas.width);


            var imgData = canvas.toDataURL("image/jpeg", 1.0);
            var pdf = new jsPDF('p', 'pt', [PDF_Width, PDF_Height]);
            pdf.addImage(imgData, 'JPG', top_left_margin, top_left_margin, canvas_image_width, canvas_image_height);


            for (var i = 1; i <= totalPDFPages; i++) {
                pdf.addPage(PDF_Width, PDF_Height);
                pdf.addImage(imgData, 'JPG', top_left_margin, -(PDF_Height * i) + (top_left_margin * 4), canvas_image_width, canvas_image_height);
            }

            pdf.save("HTML-Document.pdf");
        });
    };

</script>
