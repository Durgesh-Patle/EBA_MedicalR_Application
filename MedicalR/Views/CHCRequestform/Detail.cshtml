<input type="hidden" value="0" id="employee_id" class="hdnRelevantID" />
<input type="hidden" value="@ViewBag.Client_ID" id="emplid" class="hdnRelevantID" />
<input type="hidden" value="@ViewBag.EmpCode" id="EmpCode" class="hdnRelevantID" />
<input type="hidden" value="@ViewBag.Emplcode" id="created_by" class="hdnRelevantID" />

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script>

    var clientID = @ViewBag.Client_ID;
    var Emplcode= @ViewBag.Emplcode;
    var activeTab = window.location.hash.substring(1);
    if(activeTab=="" || clientID==0)
    {
        activeTab="info";
        window.location.hash = '#'+activeTab;
    }
    var activeView = $("#clients-tab li[data-tab='"+activeTab+"']").find("a.nav-link").data("target");
    LoadClientViews(activeView);
    LoadEmpsidebarViews();

    function LoadClientViews(targetView)
    {
        $("#clients-tab a").removeClass("active");
        $("#clients-tab a[data-target='" + targetView + "']").addClass("active");
        $("#loader").show();
        $.ajax({
            url: targetView,
            type: "post",
            data :{"clientID":clientID},
            dataType: "html",
            success: function (result) {
                $("#client-tabContent").html(result);
                $('#client-tabContent table').DataTable();
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    window.location.reload();
                    return;
                }
                $("#loader").hide();
            }

        });
    }
    function BindCHC() {
        $("#chc_centid").empty();
        var chc_centerid = $("#chc_centerid").val();
        var chc_centername = $("#chc_centerid option:selected").text();
        $("#chc_centid").append("<option value='" + chc_centerid + "'>" + chc_centername + "</option>");

    }
    function LoadEmpsidebarViews()
    {
        $.ajax({
            url: "/CHCRequestform/_Empsidebarinfo",
            type: "post",
            dataType: "html",
            success: function (result) {
                $("#client-sidebar-info").html(result);
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    window.location.reload();
                    return;
                }
            }

        });
    }

    function calculateAge() {
        var from = new Date(new Date());
        var relationship = $("#relationship").val();

        if (relationship == "Self and Spouse") {
            var to = new Date($("#dob_spouse").val());
            var sps_age = Math.abs(from.getFullYear() - to.getFullYear());
            $("#spouse_age").val(sps_age);
        }
        else if (relationship == "spouse") {
            var to = new Date($("#dobspouse").val());
            var sps_age = Math.abs(from.getFullYear() - to.getFullYear());
            $("#spouseage").val(sps_age);
        }

    }
    function autospousedatefill() {

        var date_of_checkup = $("#date_of_checkup").val().trim();
        $("#spouse_dt_of_checkup").val(date_of_checkup);

    }
    function CheckPriviousclaim(date_of_checkup) {

        var emplid = clientID;
        var relationship = $("#relationship").val();
        if (relationship == "Self and Spouse")
        {
            var date_of_checkup = $("#date_of_checkup").val();
        }
        if (relationship == "self")
        {
            var date_of_checkup = $("#dateofself").val();
        }
        if (relationship == "spouse")
        {
            var date_of_checkup = $("#spouse_dt_ofcheckup").val();
        }

        //var data = {
        //    "emplid": clientID,
        //    "date_of_checkup": date_of_checkup,

        //};
        var formData = new FormData();
        formData.append("emplid", clientID);
        formData.append("relationship", relationship);
        formData.append("date_of_checkup", date_of_checkup);
        $.ajax({
            url: "/CHCRequestform/CheckPriviousClaim",
            type: "post",
            data: formData,
            dataType: "json",
            contentType: false,
            processData: false,
            success: function (result) {
                if (result["Status"] == true) {
                    toastr["success"](result["Message"]);

                    window.location.href = "/CHCRequestform";
                }
                else {
                    //toastr["error"](result["Message"]);
                }
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    window.location.reload();
                    return;
                }
                toastr["error"]("Something went wrong. Please try after some time.");
            }
        });
    }

    function check_date_of_checkup_validity(date_of_checkup, curr_date) {

        var temp_date_of_checkup = new Date(date_of_checkup);

        // Determine the time difference between two dates
        var millisBetween = temp_date_of_checkup.getTime() - curr_date.getTime();

        // Determine the number of days between two dates
        var days = millisBetween / (1000 * 3600 * 24);
      //var calculate_days=  Math.round(Math.abs(days));
        //if (calculate_days < 8) {
        //    toastr["error"]("Kindly apply before 8 working days from date of checkup");
        //    return Math.round(Math.abs(days));
        //}
        return Math.round(Math.abs(days));
    };

