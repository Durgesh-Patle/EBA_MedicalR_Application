@model MedicalR.Models.CHC.CHCBillProcess
<form>
    <div class="form-row">
        <div class="form-group col-md-6">
            <label for="">Employee ID: </label>
            <input type="text" class="form-control" id="emplid" value="@Model.emplid">
        </div>

    </div>

    <div class="form-row">
        <div class="form-group col-md-6">
            <label for="">Employee Name: </label>
            <input type="text" class="form-control" id="employee_name" value="@Model.employee_name">
        </div>
        <div class="form-group col-md-6">

            <label for="">Name of CHC Center:</label>
            <select class="form-control" id="chc_centerid">
                <option value="@Model.chc_centerid">@Model.hosname</option>
            </select>
        </div>

    </div>


    <div class="form-row">
      
        <div class="form-group col-md-6">
            <label for="">Amount: <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="amount" value="@Model.amount">

        </div>


    </div>
  



    <div class="row">
        <div class="form-group col-md-4"></div>
        <div class="form-group col-md-4"> <a href="javascript:void(0)" class="btn btn-primary" id="Approve" data-val="1">Process for Payment<span class="spinner"></span></a> </div>
        @*<div class="form-group col-md-4"> <a href="javascript:void(0)" class="btn btn-primary" id="Hold" data-val="1">On Hold<span class="spinner"></span></a> </div>*@

    </div>

</form>

