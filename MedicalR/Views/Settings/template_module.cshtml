@model IEnumerable<MedicalR.Models.TemplateModule.TemplateModel>
@{
    ViewBag.Title = "Template Module";
}

<article class="col-md-12 mt-5 p-2">
    <div class="p-2">
        <div class="">
            <a href="/settings/template-module/add" class="btn btn-secondary float-right ml-1">+</a>
            &nbsp;
            <a href="#" class="btn btn-secondary float-right">Import</a>
        </div>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th scope="col"><input type="checkbox"></th>
                <th scope="col">Title</th>
                <th scope="col">Published</th>
                <th scope="col">Posted On</th>
                <th scope="col">Modified</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <th scope="row"><input type="checkbox"></th>
                    <td><a href="/settings/template-module/@item.templateID/edit"> @item.templateTitle</a></td>
                    <td>@item.templatePublish</td>
                    <td>@item.templatePublishDate</td>
                    <td>@item.templateLastModified</td>
                </tr>
            }

        </tbody>
    </table>
    @if (Model.Count() == 0)
    {
        <div class="no-data-found">No Data Found</div>
    }
</article>

