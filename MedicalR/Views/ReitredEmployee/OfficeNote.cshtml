
@model MedicalR.Models.RetiredEmployee.RetiredempTransModel
@{
    ViewBag.Title = "OfficeNote";
    Layout = "~/Views/Shared/_Layout.cshtml";
    <style>
        /* Style the body */
        body {
            font-family: Arial;
            margin: 0;
        }

        ex1 {
            border: 1px solid red;
            padding: 35px;
        }
        /* Header/Logo Title */
        .header {
            margin: auto;
            width: 60%;
            border: 1px solid black;
            padding: 20px;
            color: black;
            font-size: 12px;
            border-color: black;
            /* border: 1px solid red;
        padding: 20px;
        color: black;
        font-size: 10px;
        border-color:black;*/
        }

        .contents {
            margin: auto;
            width: 60%;
            padding: 5px;
            color: black;
            font-size: 16px;
        }

        /* Page Content */
        .content {
            padding: 20px;
        }
    </style>
}
<div class="container-fluid">
    <div class="row">
        <div class="col-md-12 p-0">
            @*<ul class="nav">
                    <li class="nav-item"> <a class="nav-link text-dark" href="javascript:void(0);"><strong>Statistics</strong></a> </li>
                    <li class="nav-item"> <a class="nav-link" href="#">Bill Process</a> </li>
                </ul>*@
            <hr class="m-0">
        </div>
        <article class="col-md-12">
            <div class="pt-3">
            </div>
            <div class="pt-3">
            </div>
            <div class="pt-3">
            </div>
            <div class="pt-3">

            </div>
            <div class="row">
                <div class="form-group col-md-6"></div>
                <div class="form-group col-md-4"></div>
                <button type="button" class="btn btn-primary" id="exportSubmit">Print</button>
            </div>
            <form id="exportData" action="/ReitredEmployee/OfficeGetExportToExcel" style="display:none">
                <input type="text" value="lot" name="lot" />
                <input type="hidden" id="lotno" name="lotno" value="@Model.lot_no" />
                @*<input type="text" value="" name="ToDate" />*@
            </form>

            <div class="Grid" id="Grid">
                <div class="row" id="contnet">
                    <div class="header">
                        <h3 style="text-align: center"><strong>UTI AMC Limited</strong></h3>
                        <h5 style="text-align: center"><strong>Office Note</strong></h5>

                    </div>
                    <div class="contents">

                        <p>&nbsp;</p>
                        <p style="text-align:center"><strong>Ref : Sanction of VHS Payment</strong></p>
                        <p style="text-align:right">Date:@Html.Label(Model.lot_date.ToShortDateString())</p>
                        <p>With reference to the office note dated 24-Aug-2006 sanctioned by Head (HR) the reimbursement of </p>
                        <p>medical expenditure for domiciliary treatment under Health Scheme 1991 will be done on declaration</p>
                        <p>basis. As per the note, VSS / Retired Employees have forwarded the declaration for processing.</p>
                        <p>&nbsp;</p>
                        <p>Placed below are the list of applications received for the same.</p>
                        <p>&nbsp;</p>
                        <p>If approved, we may pay Rs<span id="value"></span> to our ex-empployees towards VHS reimbursement by</p>
                        <p>debit to Medical Expense - VHS under lot No :@Model.lot_no</p>
                        <p>&nbsp;</p>
                        <table id="dtBasicExample" class="table table-hover table-bordered" cellspacing="0" width="100%">
                            <thead>
                                <tr>


                                    <th class="th-sm">From Year</th>
                                    <th class="th-sm">To Year</th>
                                    <th class="th-sm">Total Rs.</th>


                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.EmplSanc_list)
                                {
                                    <tr>



                                        <td>@item.yearfrom</td>
                                        <td>@item.yearto</td>
                                        <td>@item.sanc_amt</td>




                                    </tr>
                                }


                            </tbody>
                        </table>
                        @if (Model.EmplSanc_list.Count() == 0)
                        {
                            <div class="no-data-found">No Data Found</div>
                        }
                        <p>&nbsp;</p>
                        <div class="row">


                            <div class="form-group col-md-8"></div>
                            <p style="text-align:center"> <label style="text-align:center" for=""><strong>Total Rs. <span id="val">.</span></strong></label></p>


                        </div>

                        <p>&nbsp;</p>
                        <p>Submitted Please.</p>
                        <p>&nbsp;</p>
                        <p>&nbsp;</p>
                        <p>AM / MGR</p>
                        <p>&nbsp;</p>
                        <p>&nbsp;</p>
                        <p>AVP / VP</p>
                        <p>&nbsp;</p>
                        <p>&nbsp;</p>
                        <p>SVP / EVP</p>

                    </div>
                </div>
            </div>
            <div class="row">
                <div class="form-group col-md-3"></div>
                <div class="form-group col-md-3">
                    <button type="button" class="btn btn-primary" id="" onclick="ViewAnnexure()">View-Annexure</button>
                </div>
                <div class="form-group col-md-3">
                    <button type="button" class="btn btn-primary" onclick="back()">Back</button>
                </div>

            </div>
            <div class="row">
                <input type="hidden" id="lot_no" value="@Model.lot_no" />
            </div>
            <div id="elementH"></div>
            @* </div> *@

        </article>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

<script src="~/Includes/js/jspdf.min.js"></script>

<script src="~/Includes/js/html2canvas.js"></script>

<script>
    $(document).ready(function () {
        var table = document.getElementById("dtBasicExample"), sumVal = 0; apcount = 0;
        for (i = 1; i < table.rows.length; i++) {
            // apcount = apcount + parseInt(table.rows[i].cells[2].innerHTML);
            sumVal = sumVal + parseInt(table.rows[i].cells[2].innerHTML);

        }
        document.getElementById("val").innerHTML = ":" + sumVal;
        document.getElementById("value").innerHTML = ":" + sumVal;

        $("#exportSubmit").click(function () {

            //
            var lots = $("#lot").val();
            //var ToDate = $("#TO_DATE").val();
            var lotno = $("#lotno").val();
            $("#exportData input[name=lot]").val("test");
            $("#exportData input[name=lotno]").val();
            //$("#exportData input[name=ToDate]").val(ToDate);
            $("#exportData").submit();
        })


    });



    function back() {

        window.location.href = "/ReitredEmployee/QueryModel";
    };
    function ViewAnnexure() {
        var lotno = $("#lot_no").val().trim();
        window.location.href = "/ReitredEmployee/EmplAnnexure/" + lotno;
    };

</script>


