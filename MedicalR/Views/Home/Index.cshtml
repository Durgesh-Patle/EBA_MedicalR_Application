@using MedicalR.Models.UserManagement

@using Newtonsoft.Json


@{
    Layout = null;
    ViewBag.Title = "Login";

}

<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <title>@ViewBag.Title</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">

    <style>
        .has-error {
            color: #c30808;
            font-weight: 500;
        }

        #CaptchaImage {
            width: 157px;
        }
    </style>
</head>

<body style="background-image:url(../../Includes/img/loginbg.jpg); background-size:cover;">
    <br><br><br><br>
    <div class="container text-center mt-5 p-3 col-md-3 border shadow bg-light">
        <h3><img src="../../Includes/img/logo.png" alt="Logo" /></h3>
        <h5> Employee Benefits System </h5>

        <form method="post" action="/">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <input type="text" required class="form-control" name="EmpCode" id="exampleInputEmail1" maxlength="10" placeholder="Enter Employee Code" autocomplete="off">
                @*<input type="email" required class="form-control" name="EmailID" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="Enter email">*@
                <!--<small id="emailHelp" class="form-text text-muted">We'll never share your email with anyone else.</small>-->
            </div>
            <div class="form-group">
                <input type="password" required class="form-control" name="Password" id="exampleInputPassword1" placeholder="Password">
            </div>


            <!--Generating captcha image-->
            <img src="@Url.Action("GenerateCaptcha","Home")" id="hicaptcha" alt="qr code" width="60%" height="40" class="mt-2" />

            <div class="input-group col-md-12 mb-2 mt-3">

                <input type="text" class="form-control" id="CaptchaInput" name="CaptchaInput" />
            </div>

            <div class="form-group" style="display:none;" id="otpDiv">
                <label><b>Please Enter OTP</b></label>
                <input type="text" class="form-control" id="otpText" name="otp" placeholder="Enter OTP" />
            </div>

            <br />
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }
            @if (!string.IsNullOrEmpty(ViewBag.errorMessage))
            {

                <span class="has-error">@ViewBag.errorMessage</span>
                <br />
                <br />

            }
            <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />

            <a href="javascript:void(0);" class="btn btn-primary col-md-12 mb-4" id="sendOtp" style="margin-top: 10px;">Send OTP</a>
            @*<button type="submit" class="btn btn-primary col-md-12" id="login" style="display: none">Login</button>*@


            <button type="submit" class="btn btn-primary col-md-12" id="login" style="display:none;">Login</button>
            @*<small id="emailHelp" class="form-text text-muted"><strong>Forgot Password? <a href="/forget-password" class="text-primary"><span class="text-primary">Click here</span></a></strong></small>
                <small id="emailHelp" class="form-text text-muted"><strong><a href="/register" class="text-primary"><span class="text-primary">Create an account</span></a></strong></small>*@
        </form>
    </div>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- CryptoJS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>

    <script>
   $(document).ready(function () {
    debugger;

    var errorMessage = '@TempData["ErrorMessage"]';
    var errorstatus = '@TempData["LockStatus"]';

    if (!errorMessage || errorMessage.trim() === '') {
        return;
    } else {
       var model = @Html.Raw(JsonConvert.SerializeObject(Model));

        $('#exampleInputEmail1').val(model?.EmpCode || '');
        $('#exampleInputPassword1').val(model?.Password || '');
        $('#otpText').val(model?.otp || '');
        console.log(model);
        $("#CaptchaInput").attr('hidden', true);
        $("#otpDiv").show();
        $("#sendOtp").hide();
        $("#hicaptcha").hide();
        $("#login").show();
        if (errorstatus === 'True') {
            setTimeout(function () {
                window.location.href = "http://localhost:56654/";
            }, 10000);

        }
    }
});
    </script>

    <script>

        $("form").on("submit", function (e) {

            let empCode = $("#exampleInputEmail1").val().trim();
            let password = $("#exampleInputPassword1").val().trim();

            if (!empCode || !password) {
                alert("Employee Code and Password are required!");
                e.preventDefault();
                return false;
            }

            var key = CryptoJS.enc.Utf8.parse("UTILoginKey12345");
            var iv = CryptoJS.enc.Utf8.parse("UTILoginKey12345");

            var encryptedEmp = CryptoJS.AES.encrypt(empCode, key, {
                iv: iv,
                mode: CryptoJS.mode.CBC,
                padding: CryptoJS.pad.Pkcs7
            }).toString();

            var encryptedPass = CryptoJS.AES.encrypt(password, key, {
                iv: iv,
                mode: CryptoJS.mode.CBC,
                padding: CryptoJS.pad.Pkcs7
            }).toString();

            // 🔁 Replace original values
            $("#exampleInputEmail1").val(encryptedEmp);
            $("#exampleInputPassword1").val(encryptedPass);

            setTimeout(function () {
                $("#exampleInputEmail1").val(empCode);
                $("#exampleInputPassword1").val(password);
            }, 0);
        });


    document.addEventListener("keypress", function (e) {
    if (e.key === "Enter" || e.keyCode === 13) {
        debugger
        e.preventDefault();

        var loginElement = document.getElementById("login");

        if (loginElement && loginElement.style.display === "none") {
            sendOtp();
        } else {
            var loginButton = document.getElementById("login");
            if (loginButton) {
                loginButton.click();
            }
        }
    }
    });

      $(document).ready(function () {
          $("#sendOtp").click(function (e) {
              e.preventDefault();
              sendOtp();
          });
      });

      function sendOtp() {
          let empCode = $("#exampleInputEmail1").val().trim();
          let emailMobNo = $("#CaptchaInput").val().trim();
          let password = $("#exampleInputPassword1").val().trim();
          if (empCode === '') {
              alert("Employee Code cannot be empty!");
              $("#exampleInputEmail1").focus();
              return;
          }

          if (password === '') {
              alert("Password cannot be empty!");
              $("#exampleInputPassword1").focus();
              return;
          }

          if (emailMobNo === '') {
              alert("Captcha cannot be empty!");
              $("#CaptchaInput").focus();
              return;
          }
          //let secretKey = "UTILoginKey12345";  // Same key will be used in C#

          //let encryptedEmp = CryptoJS.AES.encrypt(empCode, secretKey).toString();
          //let encryptedPass = CryptoJS.AES.encrypt(password, secretKey).toString();
          var key = CryptoJS.enc.Utf8.parse("UTILoginKey12345"); // 16 bytes
          var iv = CryptoJS.enc.Utf8.parse("UTILoginKey12345"); // 16 bytes (same)

          var encryptedEmp = CryptoJS.AES.encrypt(empCode, key, {
              iv: iv,
              mode: CryptoJS.mode.CBC,
              padding: CryptoJS.pad.Pkcs7
          }).toString();

          var encryptedPass = CryptoJS.AES.encrypt(password, key, {
              iv: iv,
              mode: CryptoJS.mode.CBC,
              padding: CryptoJS.pad.Pkcs7
          }).toString();


          let data = {
              //EmpCode: empCode,

              //Password: password,
              EmpCode: encryptedEmp,
              Password: encryptedPass,

              CaptchaInput: emailMobNo

          };

          $.ajax({

              url: '@Url.Action("SendOtpForLogin", "Home")',

              method: 'POST',

              contentType: "application/x-www-form-urlencoded; charset=UTF-8",

              data: data,

              success: function (response) {

                  if (response && response.success) {
                      $("#exampleInputEmail1").val(empCode);
                      $("#exampleInputPassword1").val(password);


                      $("#CaptchaInput").prop('disabled', true);

                      $("#otpDiv").show();

                      $("#login").show();

                      $("input[name='EmpCode']").prop('readonly', true);

                      $("input[type='password']").prop('readonly', true);

                      $("#sendOtp").hide();

                      $("#confirmOtpBtn").show();

                  } else {

                      alert(response.message || "Failed to send OTP.");

                  }

              },

              error: function (xhr, status, error) {

                  console.error("Error details:", status, error);

                  alert("An error occurred while sending OTP. Please try again.");

              }

          });

      }

    </script>
</body>

</html>


